{
  // Friendly name shown in VS Code and GitHub Codespaces
  "name": "Instant Dev Environment Lab",

  // Build the development container from the local Dockerfile
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  // Default workspace location inside the container
  "workspaceFolder": "/workspaces/instant-dev-environment-lab",

  // Use the default non-root user included in Microsoft Dev Container base images
  "remoteUser": "vscode",

  // Run setup and health-check scripts after the container is created
